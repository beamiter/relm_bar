<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache -->
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkApplicationWindow" id="main_window">
    <property name="decorated">false</property>
    <property name="default-height">40</property>
    <property name="default-width">1000</property>
    <property name="resizable">true</property>
    <property name="title">relm_bar</property>
    <child>
      <object class="GtkBox" id="top_hbox">
        <property name="margin-bottom">3</property>
        <property name="margin-end">3</property>
        <property name="margin-start">3</property>
        <property name="margin-top">3</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">3</property>
        <style><class name="panel-root"/></style>
        <child>
          <object class="GtkBox" id="tab_box">
            <property name="orientation">horizontal</property>
            <property name="spacing">3</property>

            <!-- 9 个工作区按钮 -->
            <child>
              <object class="GtkButton" id="tab_button_0">
                <property name="height-request">32</property>
                <property name="label">🍜</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="tab_button_1">
                <property name="height-request">32</property>
                <property name="label">🎨</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="tab_button_2">
                <property name="height-request">32</property>
                <property name="label">🍀</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="tab_button_3">
                <property name="height-request">32</property>
                <property name="label">🧿</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="tab_button_4">
                <property name="height-request">32</property>
                <property name="label">🌟</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="tab_button_5">
                <property name="height-request">32</property>
                <property name="label">🐐</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="tab_button_6">
                <property name="height-request">32</property>
                <property name="label">🏆</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="tab_button_7">
                <property name="height-request">32</property>
                <property name="label">🕊️</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="tab_button_8">
                <property name="height-request">32</property>
                <property name="label">🏡</property>
                <property name="width-request">40</property>
                <style><class name="tab-button"/></style>
              </object>
            </child>
          </object>
        </child>

        <!-- 布局开关（pill） -->
        <child>
          <object class="GtkButton" id="layout_toggle">
            <property name="height-request">32</property>
            <property name="width-request">48</property>
            <property name="label">[]=</property>
            <style>
              <class name="layout-toggle"/>
              <class name="closed"/>
            </style>
          </object>
        </child>

        <!-- 可展开的布局选项（GtkRevealer 动画） -->
        <child>
          <object class="GtkRevealer" id="layout_revealer">
            <property name="reveal-child">false</property>
            <property name="transition-type">slide-right</property>
            <property name="transition-duration">120</property>
            <child>
              <object class="GtkBox" id="layout_selector_box">
                <property name="orientation">horizontal</property>
                <property name="spacing">5</property>
                <style><class name="layout-selector"/></style>
                <child>
                  <object class="GtkButton" id="layout_option_tiled">
                    <property name="height-request">28</property>
                    <property name="width-request">40</property>
                    <property name="label">[]=</property>
                    <style><class name="layout-option"/></style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="layout_option_floating">
                    <property name="height-request">28</property>
                    <property name="width-request">40</property>
                    <property name="label">&gt;&lt;&gt;</property>
                    <style><class name="layout-option"/></style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="layout_option_monocle">
                    <property name="height-request">28</property>
                    <property name="width-request">40</property>
                    <property name="label">[M]</property>
                    <style><class name="layout-option"/></style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- 中间撑开 -->
        <child>
          <object class="GtkBox" id="spacer">
            <property name="hexpand">true</property>
            <property name="orientation">horizontal</property>
          </object>
        </child>

        <!-- 右侧信息：CPU/MEM/截图/时间/监视器 -->
        <child>
          <object class="GtkBox" id="right_box">
            <property name="halign">end</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">3</property>

            <child>
              <object class="GtkLabel" id="cpu_label">
                <property name="justify">center</property>
                <property name="label">CPU</property>
                <property name="width-request">60</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="memory_label">
                <property name="label">MEM</property>
                <property name="width-request">60</property>
              </object>
            </child>

            <child>
              <object class="GtkButton" id="volume_button">
                <property name="height-request">32</property>
                <property name="label"> 🔊 --% </property>
                <property name="width-request">90</property>
                <style><class name="volume-button"/></style>
              </object>
            </child>

            <child>
              <object class="GtkButton" id="theme_button">
                <property name="height-request">32</property>
                <property name="label"> 🌙 </property>
                <property name="width-request">46</property>
                <style><class name="theme-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="screenshot_button">
                <property name="height-request">32</property>
                <property name="label"> 📸 </property>
                <property name="width-request">60</property>
                <style><class name="screenshot-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="time_label">
                <property name="height-request">32</property>
                <property name="label">--:--</property>
                <property name="width-request">120</property>
                <style><class name="time-button"/></style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="monitor_label">
                <property name="halign">center</property>
                <property name="height-request">32</property>
                <property name="label">🥇</property>
                <property name="width-request">30</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
